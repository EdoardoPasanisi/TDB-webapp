# Public app URLs
NEXT_PUBLIC_SITE_URL=https://app.example.com
NEXT_PUBLIC_AUTH_REDIRECT_BASE_URL=https://app.example.com
ALLOWED_ORIGINS=https://app.example.com

# Login social nativo (app iOS). OAuth client di tipo "iOS" creato su Google Cloud.
# Senza questo valore il pulsante Google viene nascosto dentro l'app (nel browser resta).
# Apple non richiede nulla: in nativo il client è il bundle id dell'app.
NEXT_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxx-xxxxx.apps.googleusercontent.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# OpenAI chatbot
OPENAI_API_KEY=replace-me
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Email notifications
RESEND_API_KEY=replace-me
RESEND_FROM_EMAIL="Tenuta del Barone <no-reply@example.com>"
RESEND_REPLY_TO_EMAIL=info@example.com

# Taxi dog distance origin
TENUTADELBARONE_BUSINESS_ADDRESS="Via Davide Passigli 60, Fiumicino, RM, Italia"
